# Required for cli: claude — OAuth token from `claude login`
CLAUDE_CODE_OAUTH_TOKEN=...

# Required for cli: codex — authenticate first with `codex login`
# No env var needed; auth is read from ~/.codex (mounted as volume)

# Required: GitHub (PAT with repo, workflow scopes)
GITHUB_TOKEN=ghp_...

# Required: Auth.js session encryption (generate with: openssl rand -hex 32)
AUTH_SECRET=generate-with-openssl-rand-hex-32

# Optional: Set to "true" to skip auth entirely (single-user mode)
# AUTH_DISABLED=true

# Optional: Signups are disabled by default. Set to "false" to allow new users to register.
# SIGNUP_DISABLED=false

# Optional: Email notifications via Resend
RESEND_API_KEY=re_...

# Optional: Git commit identity (shown on commits and PRs)
# To link to a GitHub profile, use that account's noreply email:
#   GIT_AUTHOR_EMAIL=username@users.noreply.github.com
GIT_AUTHOR_NAME=Karna Agent
GIT_AUTHOR_EMAIL=agent@karna.dev

# Optional: Frontend URL for CORS (default: http://localhost:3000)
# Set this to your frontend's public URL if using a reverse proxy or tunnel.
# Must not have a trailing slash. Example: https://app.yourdomain.com
# FRONTEND_URL=http://localhost:3000

# Optional: Customize ports
FRONTEND_PORT=3000
CODE_SERVER_PORT=8443
POSTGRES_PORT=5432
REDIS_PORT=6379

# Optional: Passwords
POSTGRES_PASSWORD=karna
CODE_SERVER_PASSWORD=changeme

# Optional: Cloudflare Tunnel (for public access without port forwarding)
# Run: docker compose --profile tunnel up
#
# Mode 1: Token-based (routes managed in CF dashboard)
#   Create tunnel in CF Zero Trust dashboard, copy the token.
# CLOUDFLARE_TUNNEL_TOKEN=
#
# Mode 2: Credentials-based (routes defined in code — recommended)
#   One-time setup:
#     cloudflared tunnel create karna
#     cloudflared tunnel route dns karna app.yourdomain.com
#     cloudflared tunnel route dns karna code.yourdomain.com
#   Then base64 the credentials file:
#     base64 < ~/.cloudflared/<TUNNEL_ID>.json
# CLOUDFLARE_TUNNEL_ID=
# CLOUDFLARE_TUNNEL_CREDENTIALS=  # base64 of ~/.cloudflared/<TUNNEL_ID>.json
# TUNNEL_FRONTEND_HOSTNAME=app.yourdomain.com
# TUNNEL_CODE_SERVER_HOSTNAME=code.yourdomain.com
# TUNNEL_AGENT_HOSTNAME=agent.yourdomain.com

# Optional: GitHub Webhooks (auto-registered on repos during onboarding)
# The agent derives the webhook URL from AGENT_WEBHOOK_URL, falling back to
# TUNNEL_AGENT_HOSTNAME. Set a secret for HMAC-SHA256 signature verification.
# GITHUB_TOKEN needs admin:repo_hook scope for auto-registration.
# AGENT_WEBHOOK_URL=         # Full URL override (e.g. https://your-ngrok-url.ngrok.io)
# GITHUB_WEBHOOK_SECRET=     # generate with: openssl rand -hex 32
